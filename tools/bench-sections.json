{
  "meta": {
    "criterion_dir": "target/criterion",
    "alloc_budget_path": "alloc_budget.json",
    "target_file": "docs/performance.md"
  },
  "sections": {
    "slo": {
      "description": "Service-Level Objectives table",
      "type": "slo",
      "metrics": [
        {
          "label": "Full frame CPU (80×24)",
          "slo": "p99 < 200 μs",
          "threshold": 200,
          "bench": "full_frame",
          "unit": "us"
        },
        {
          "label": "Per-plugin WASM overhead",
          "slo": "< 3 μs/plugin",
          "threshold": 3,
          "bench": "multi_plugin/full_frame/1",
          "unit": "us"
        },
        {
          "label": "Per-frame allocation (warm)",
          "slo": "< 150 allocs",
          "threshold": 150,
          "alloc_key": "full_frame.count",
          "unit": "allocs"
        },
        {
          "label": "state.apply(Draw) 100 lines",
          "slo": "< 200 μs",
          "threshold": 200,
          "bench": "state_apply/draw_lines/100",
          "unit": "us"
        }
      ]
    },
    "per_frame_cost": {
      "description": "Per-Frame Cost (80x24) table",
      "type": "table",
      "columns": ["Phase", "Complexity", "Measured", "Notes"],
      "rows": [
        {
          "label": "`view()`",
          "complexity": "O(nodes)",
          "bench": "element_construct/plugins_0",
          "unit": "us",
          "note_tpl": "{val} (0 plugins) / {val2} (10 plugins)",
          "bench2": "element_construct/plugins_10",
          "col_measured": "note_tpl"
        },
        {
          "label": "`place()`",
          "complexity": "O(nodes)",
          "bench": "flex_layout",
          "unit": "us"
        },
        {
          "label": "`grid.clear()`",
          "complexity": "O(w*h)",
          "bench": "grid_clear/80x24",
          "unit": "us"
        },
        {
          "label": "`paint()`",
          "complexity": "O(w*h)",
          "bench": "paint/80x24",
          "unit": "us",
          "derived": { "op": "subtract", "base": "paint/80x24", "sub": "grid_clear/80x24" },
          "note": "paint-only = clear+paint − clear"
        },
        {
          "label": "`grid.diff()` (incremental)",
          "complexity": "O(w*h) = 1,920 cells",
          "bench": "grid_diff/incremental",
          "unit": "us"
        },
        {
          "label": "`grid.diff()` (full redraw)",
          "complexity": "O(w*h)",
          "bench": "grid_diff/full_redraw",
          "unit": "us",
          "note": "First frame only; builds all CellDiffs"
        },
        {
          "label": "**CPU pipeline total**",
          "complexity": "",
          "bench": "full_frame",
          "unit": "us",
          "bold": true
        },
        {
          "label": "`backend.draw_grid()`",
          "complexity": "O(changed_cells)",
          "bench_range": ["draw_grid/incremental_1line", "draw_grid/full_redraw/80x24"],
          "unit": "us",
          "note": "Zero-copy diff + incremental SGR + I/O"
        }
      ]
    },
    "alloc_breakdown": {
      "description": "Allocation Breakdown (Per-Phase) table",
      "type": "alloc",
      "phases": ["view", "place", "paint", "diff", "swap"],
      "total": "full_frame",
      "extra": { "key": "parse_request_100", "label": "parse_request (100 lines)" }
    },
    "micro": {
      "description": "Micro Benchmarks table",
      "type": "bench_table",
      "columns": ["Benchmark", "What It Measures", "Target", "Measured", "Verdict"],
      "rows": [
        { "bench": "element_construct/plugins_0",  "what": "view() tree construction (0 plugins)",      "target": "< 10 us", "target_val": 10, "unit": "us" },
        { "bench": "element_construct/plugins_10", "what": "view() tree construction (10 plugins)",     "target": "< 15 us", "target_val": 15, "unit": "us" },
        { "bench": "flex_layout",                  "what": "place() layout calculation",                "target": "< 5 us",  "target_val": 5,  "unit": "us" },
        { "bench": "paint/80x24",                  "what": "clear() + paint() combined",                "target": "--",      "unit": "us",     "derived_note": { "op": "subtract", "base": "paint/80x24", "sub": "grid_clear/80x24", "suffix": "paint-only" } },
        { "bench": "paint/200x60",                 "what": "clear() + paint() combined (large)",        "target": "--",      "unit": "us",     "derived_note": { "op": "subtract", "base": "paint/200x60", "sub": "grid_clear/200x60", "suffix": "paint-only" } },
        { "bench": "paint/80x24_realistic",        "what": "clear() + paint() combined (varied Face/lengths)", "target": "--", "unit": "us",   "derived_note": { "op": "subtract", "base": "paint/80x24_realistic", "sub": "grid_clear/80x24", "suffix": "paint-only" } },
        { "bench": "grid_clear/80x24",             "what": "clear() standalone",                        "target": "--",      "unit": "us" },
        { "bench": "grid_clear/200x60",            "what": "clear() standalone (large)",                "target": "--",      "unit": "us" },
        { "bench": "grid_diff/full_redraw",        "what": "diff() first frame",                        "target": "--",      "unit": "us",     "note": "First frame only" },
        { "bench": "grid_diff/incremental",        "what": "diff() no changes",                         "target": "--",      "unit": "us",     "note": "Steady-state path" }
      ]
    },
    "integration": {
      "description": "Integration Benchmarks table",
      "type": "bench_table",
      "columns": ["Benchmark", "What It Measures", "Target", "Measured", "Verdict"],
      "rows": [
        { "bench": "full_frame",                "what": "view -> layout -> paint -> diff -> swap", "target": "< 16 ms", "target_val": 16000, "unit": "us" },
        { "bench": "draw_message",              "what": "state.apply(Draw) + full frame",          "target": "< 5 ms",  "target_val": 5000,  "unit": "us" },
        { "bench": "menu_show/items/10",        "what": "Menu display + full frame",               "target": "< 5 ms",  "target_val": 5000,  "unit": "us" },
        { "bench": "menu_show/items/50",        "what": "Menu 50 items + full frame",              "target": "< 5 ms",  "target_val": 5000,  "unit": "us" },
        { "bench": "menu_show/items/100",       "what": "Menu 100 items + full frame",             "target": "< 5 ms",  "target_val": 5000,  "unit": "us" },
        { "bench": "incremental_edit/lines/1",  "what": "1 line edit -> view + paint + diff",      "target": "--",      "unit": "us" },
        { "bench": "incremental_edit/lines/5",  "what": "5 line edit -> view + paint + diff",      "target": "--",      "unit": "us" },
        { "bench": "message_sequence",          "what": "draw_status + draw -> full frame",        "target": "--",      "unit": "us" }
      ]
    },
    "parse_request": {
      "description": "JSON-RPC Parsing table",
      "type": "bench_table",
      "columns": ["Benchmark", "What It Measures", "Measured", "Notes"],
      "rows": [
        { "bench": "parse_request/draw_lines/10",  "what": "JSON-RPC parse (10-line draw)",    "unit": "us" },
        { "bench": "parse_request/draw_lines/100", "what": "JSON-RPC parse (100-line draw)",   "unit": "us" },
        { "bench": "parse_request/draw_lines/500", "what": "JSON-RPC parse (500-line draw)",   "unit": "ms" },
        { "bench": "parse_request/draw_status",    "what": "JSON-RPC parse (draw_status)",     "unit": "us", "note": "Small message, high frequency" },
        { "bench": "parse_request/menu_show_50",   "what": "JSON-RPC parse (menu_show 50 items)", "unit": "us" }
      ]
    },
    "state_apply": {
      "description": "State Application table",
      "type": "bench_table",
      "columns": ["Benchmark", "What It Measures", "Measured", "Notes"],
      "rows": [
        { "bench": "state_apply/draw_lines/23",   "what": "state.apply(Draw) standalone",     "unit": "us", "note": "Includes detect_cursors + compute_lines_dirty" },
        { "bench": "state_apply/draw_lines/100",  "what": "state.apply(Draw) standalone",     "unit": "us", "note": "O(lines × atoms) cursor scanning" },
        { "bench": "state_apply/draw_lines/500",  "what": "state.apply(Draw) standalone",     "unit": "us" },
        { "bench": "state_apply/draw_status",     "what": "state.apply(DrawStatus)",          "unit": "us" },
        { "bench": "state_apply/menu_show_50",    "what": "state.apply(MenuShow)",            "unit": "us" }
      ]
    },
    "scaling": {
      "description": "Scaling Characteristics table",
      "type": "bench_table",
      "columns": ["Benchmark", "What It Measures", "Measured", "Notes"],
      "rows": [
        { "bench": "scaling/full_frame/80x24",          "what": "Full frame at 80x24",           "unit": "us", "note": "Baseline" },
        { "bench": "scaling/full_frame/200x60",         "what": "Full frame at 200x60",          "unit": "us", "ratio_base": "scaling/full_frame/80x24", "ratio_label": "area ratio: 6.25x" },
        { "bench": "scaling/full_frame/300x80",         "what": "Full frame at 300x80",          "unit": "us", "ratio_base": "scaling/full_frame/80x24", "ratio_label": "area ratio: 12.5x" },
        { "bench": "scaling/parse_apply_draw/500",      "what": "Parse + apply (500 lines)",     "unit": "ms" },
        { "bench": "scaling/parse_apply_draw/1000",     "what": "Parse + apply (1000 lines)",    "unit": "ms", "note": "Near-linear" },
        { "bench": "scaling/diff_incremental/80x24",    "what": "diff() no-change 80x24",        "unit": "us" },
        { "bench": "scaling/diff_incremental/200x60",   "what": "diff() no-change 200x60",       "unit": "us", "ratio_base": "scaling/diff_incremental/80x24", "ratio_label": "area ratio: 6.25x" },
        { "bench": "scaling/diff_incremental/300x80",   "what": "diff() no-change 300x80",       "unit": "us", "ratio_base": "scaling/diff_incremental/80x24", "ratio_label": "area ratio: 12.5x" }
      ]
    },
    "draw_grid": {
      "description": "draw_grid (ADR-015 optimized path) table",
      "type": "bench_table",
      "columns": ["Benchmark", "What It Measures", "Measured", "Notes"],
      "rows": [
        { "bench": "draw_grid/full_redraw/80x24",           "what": "80x24 all cells",          "unit": "us", "note": "Cursor auto-advance + incremental SGR" },
        { "bench": "draw_grid/full_redraw/200x60",          "what": "200x60 all cells",         "unit": "us", "note": "Large screen" },
        { "bench": "draw_grid/incremental_1line",            "what": "1 line changed",           "unit": "us", "note": "Diff + SGR for changed row" },
        { "bench": "draw_grid/full_redraw_realistic/80x24", "what": "Realistic data at 80x24",  "unit": "us", "note": "Diverse Face values" }
      ]
    },
    "backend_draw": {
      "description": "draw (legacy CellDiff path) table",
      "type": "bench_table",
      "columns": ["Benchmark", "What It Measures", "Measured", "Notes"],
      "rows": [
        { "bench": "backend_draw/full_redraw/80x24",           "what": "80x24 all cells",          "unit": "us", "note": "Escape sequence generation" },
        { "bench": "backend_draw/full_redraw/200x60",          "what": "200x60 all cells",         "unit": "us", "note": "Large screen" },
        { "bench": "backend_draw/incremental_1line",            "what": "1 line changed",           "unit": "us", "note": "Most common pattern" },
        { "bench": "backend_draw/full_redraw_realistic/80x24", "what": "Realistic data at 80x24",  "unit": "us", "note": "Diverse Face values" }
      ]
    },
    "e2e_pipeline": {
      "description": "E2E Pipeline table",
      "type": "bench_table",
      "columns": ["Benchmark", "What It Measures", "Measured", "Notes"],
      "rows": [
        { "bench": "e2e_pipeline/json_to_escape_80x24",    "what": "Full pipeline (uniform data)",    "unit": "us" },
        { "bench": "e2e_pipeline/json_to_escape_realistic", "what": "Full pipeline (realistic data)",  "unit": "us" }
      ]
    },
    "replay": {
      "description": "Replay Benchmarks table",
      "type": "replay",
      "rows": [
        { "bench": "replay/normal_editing_50msg",   "label": "`normal_editing_50msg`",   "messages": 50 },
        { "bench": "replay/fast_scroll_100msg",     "label": "`fast_scroll_100msg`",     "messages": 100 },
        { "bench": "replay/menu_completion_20msg",  "label": "`menu_completion_20msg`",  "messages": 20 },
        { "bench": "replay/mixed_session_200msg",   "label": "`mixed_session_200msg`",   "messages": 200 }
      ]
    },
    "gpu": {
      "description": "GPU CPU-Side Benchmarks table",
      "type": "bench_table",
      "columns": ["Benchmark", "What It Measures", "Measured", "Notes"],
      "rows": [
        { "bench": "gpu_bg_instances_80x24",      "what": "Background rectangle instance generation", "unit": "us" },
        { "bench": "gpu_row_hash_24rows",         "what": "Row content hashing (24 rows)",            "unit": "us", "note": "Change detection for GPU" },
        { "bench": "gpu_row_spans_80cols",        "what": "Row span computation (80 cols)",            "unit": "ns" },
        { "bench": "gpu_color_resolve_1920cells", "what": "Color resolution for 1,920 cells",         "unit": "us", "note": "Theme color -> RGBA" }
      ]
    },
    "salsa_sync": {
      "description": "Salsa Input Synchronization table",
      "type": "bench_table",
      "columns": ["Benchmark", "Measured", "Notes"],
      "rows": [
        { "bench": "salsa_sync_inputs/buffer_content/23_lines",     "unit": "us", "note": "Typical viewport" },
        { "bench": "salsa_sync_inputs/buffer_content/59_lines",     "unit": "us", "note": "Large viewport" },
        { "bench": "salsa_sync_inputs/buffer_content/79_lines",     "unit": "us" },
        { "bench": "salsa_sync_inputs/buffer_content_realistic_23", "unit": "us", "note": "Realistic face distribution" },
        { "bench": "salsa_sync_inputs/buffer_cursor_only",          "unit": "ns", "note": "Cursor move, no buffer change" },
        { "bench": "salsa_sync_inputs/status",                      "unit": "ns", "note": "Status bar update only" },
        { "bench": "salsa_sync_inputs/menu_100_items",              "unit": "us" },
        { "bench": "salsa_sync_inputs/all_flags_80x24",             "unit": "us", "note": "All flags dirty at 80x24" },
        { "bench": "salsa_sync_inputs/all_flags_300x80",            "unit": "us", "note": "All flags dirty at 300x80" }
      ]
    },
    "salsa_vs_legacy": {
      "description": "Salsa vs Legacy Pipeline table",
      "type": "paired",
      "columns": ["Scenario", "Salsa", "Legacy", "Difference"],
      "pairs": [
        { "label": "Full cold (80x24)",  "a": "salsa_vs_legacy/full_cold_salsa",          "b": "salsa_vs_legacy/full_cold_legacy",          "unit": "us" },
        { "label": "Menu select warm",   "a": "salsa_vs_legacy/menu_select_warm_salsa",   "b": "salsa_vs_legacy/menu_select_warm_legacy",   "unit": "us" },
        { "label": "Incremental edit",   "a": "salsa_vs_legacy/incremental_edit_salsa",   "b": "salsa_vs_legacy/incremental_edit_legacy",   "unit": "us" }
      ]
    },
    "salsa_scaling": {
      "description": "Salsa Scaling Advantage table",
      "type": "paired",
      "columns": ["Screen size", "Salsa", "Legacy", "Improvement"],
      "pairs": [
        { "label": "80×24",   "a": "salsa_scaling/full_frame/80x24",  "b": "scaling/full_frame/80x24",  "unit": "us" },
        { "label": "200×60",  "a": "salsa_scaling/full_frame/200x60", "b": "scaling/full_frame/200x60", "unit": "us" },
        { "label": "300×80",  "a": "salsa_scaling/full_frame/300x80", "b": "scaling/full_frame/300x80", "unit": "us" }
      ]
    },
    "salsa_patched": {
      "description": "Salsa Patched Path table",
      "type": "bench_table",
      "columns": ["Benchmark", "Measured", "Notes"],
      "rows": [
        { "bench": "salsa_patched/status_update", "unit": "us", "note": "Status-only PaintPatch via Salsa" },
        { "bench": "salsa_scene/cold",            "unit": "us", "note": "Scene cache cold start" },
        { "bench": "salsa_scene/warm",            "unit": "us", "note": "Scene cache warm (cached DrawCommands)" }
      ]
    },
    "cache_view_scene": {
      "description": "View and Scene Caching table",
      "type": "bench_table",
      "columns": ["Benchmark", "Measured", "Notes"],
      "rows": [
        { "bench": "view_cache/menu_select_cold",  "unit": "us", "note": "Cold cache: full view rebuild" },
        { "bench": "view_cache/menu_select_warm",  "unit": "us", "note": "Warm: base subtree cached, menu rebuilt" },
        { "bench": "scene_cache_cold",             "unit": "us", "note": "Cold: full scene construction" },
        { "bench": "scene_cache_warm",             "unit": "us", "note": "Warm: cached DrawCommands" },
        { "bench": "scene_cache_menu_select",      "unit": "us", "note": "Menu section rebuild only" }
      ]
    },
    "section_patch": {
      "description": "Section and Patch Paint table",
      "type": "bench_table_vs",
      "columns": ["Benchmark", "Measured", "vs full_frame", "Notes"],
      "full_frame_bench": "full_frame",
      "rows": [
        { "bench": "section_paint_status_only",  "unit": "us", "note": "STATUS-only sectioned repaint" },
        { "bench": "section_paint_menu_select",  "unit": "us", "note": "MENU_SELECTION sectioned repaint" },
        { "bench": "patch_status_update",        "unit": "us", "note": "StatusBarPatch: ~80 cells" },
        { "bench": "patch_menu_select",          "unit": "us", "note": "MenuSelectionPatch: ~10 cells" },
        { "bench": "patch_cursor_move",          "unit": "us", "note": "CursorPatch: 2 cells" }
      ]
    },
    "line_dirty": {
      "description": "Line-Dirty Optimization table",
      "type": "bench_table",
      "columns": ["Benchmark", "Measured", "Notes"],
      "rows": [
        { "bench": "line_dirty_single_edit",                  "unit": "us", "note": "1 line changed: selective_clear + paint" },
        { "bench": "line_dirty_all_changed",                  "unit": "us", "note": "All lines dirty: full repaint" },
        { "bench": "line_dirty_buffer_status/1_line_changed", "unit": "us", "note": "BUFFER|STATUS combo, 1 line" }
      ]
    },
    "bottleneck_detect_cursors": {
      "description": "detect_cursors() cost table in bottleneck analysis",
      "type": "bench_table",
      "columns": ["Lines", "state_apply(Draw)", "Notes"],
      "rows": [
        { "bench": "state_apply/draw_lines/23",  "unit": "us", "note": "Typical viewport" },
        { "bench": "state_apply/draw_lines/100", "unit": "us", "note": "Large viewport" },
        { "bench": "state_apply/draw_lines/500", "unit": "us", "note": "Exceeds 200 μs budget" }
      ]
    },
    "wasm_raw": {
      "description": "Raw WASM Overhead table",
      "type": "bench_table",
      "columns": ["Benchmark", "Measured", "Notes"],
      "rows": [
        { "bench": "empty_call/wasm_noop",          "unit": "ns", "note": "WASM boundary crossing cost" },
        { "bench": "integer_call/wasm_add",       "unit": "ns" },
        { "bench": "host_import/1x",              "unit": "ns", "note": "Guest → host function call" },
        { "bench": "host_import/10x",             "unit": "ns", "note": "~5 ns per additional host call" },
        { "bench": "empty_call/native_noop",      "unit": "ns", "note": "Baseline comparison" }
      ]
    },
    "wasm_cm": {
      "description": "Component Model Call Overhead table",
      "type": "wasm_cm",
      "pairs": [
        { "label": "noop",              "raw": "empty_call/wasm_noop",             "cm": "cm_calls/noop",                     "unit": "ns" },
        { "label": "add",               "raw": "integer_call/wasm_add",           "cm": "cm_calls/add",                      "unit": "ns" },
        { "label": "echo_string 100B",  "raw": "string_passing/write_echo/100",   "cm": "cm_calls/echo_string_100",          "unit": "ns" },
        { "label": "build_gutter 24",   "raw": "element_construction/gutter_24",  "cm": "cm_calls/build_gutter_24",          "unit": "us" },
        { "label": "on_state_changed",  "raw": "host_fn_density/state_changed_3calls", "cm": "cm_calls/on_state_changed",    "unit": "ns" },
        { "label": "contribute_lines 24","raw": "host_fn_density/contribute_lines_24", "cm": "cm_calls/contribute_lines_24", "unit": "ns" },
        { "label": "full_cycle",        "raw": "host_fn_density/full_cycle_state_lines", "cm": "cm_calls/full_cycle",        "unit": "ns" }
      ]
    },
    "wasm_realistic": {
      "description": "Realistic Plugin Simulation table",
      "type": "bench_table_vs",
      "columns": ["Scenario", "Measured", "Budget (~57 μs)", "Notes"],
      "full_frame_bench": "full_frame",
      "rows": [
        { "bench": "multi_plugin/full_frame/1",  "unit": "us", "label": "1 plugin full frame" },
        { "bench": "multi_plugin/full_frame/3",  "unit": "us", "label": "3 plugins full frame" },
        { "bench": "multi_plugin/full_frame/5",  "unit": "us", "label": "5 plugins full frame" },
        { "bench": "multi_plugin/full_frame/10", "unit": "us", "label": "10 plugins full frame" },
        { "bench": "cursor_line_plugin/cache_hit_no_call",  "unit": "ns", "label": "Cache hit (no state change)", "note": "DirtyFlags skip" }
      ]
    },
    "wasm_native": {
      "description": "WASM vs Native Comparison table",
      "type": "wasm_native",
      "pairs": [
        { "label": "cursor_line full cycle", "native": "native_baseline/native_cursor_line_full", "wasm": "cm_calls/full_cycle",     "unit": "ns", "note": "Absolute cost (2 μs) is negligible" },
        { "label": "gutter_24",              "native": "native_baseline/native_gutter_24",        "wasm": "cm_calls/build_gutter_24", "unit": "ns", "note": "Ratio drops with real computation" }
      ]
    },
    "wasm_instantiation": {
      "description": "Instantiation Cost table",
      "type": "bench_table",
      "columns": ["Operation", "Measured", "Notes"],
      "rows": [
        { "bench": "cm_instantiation/component_new", "unit": "ms", "label": "Component compilation",  "note": "One-time at startup" },
        { "bench": "instantiation_scaling/instantiate_n/1",  "unit": "us", "label": "1 instance",    "note": "Per-Store" },
        { "bench": "instantiation_scaling/instantiate_n/5",  "unit": "us", "label": "5 instances" },
        { "bench": "instantiation_scaling/instantiate_n/10", "unit": "us", "label": "10 instances" }
      ]
    }
  }
}
